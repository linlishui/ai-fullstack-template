# Application
APP_NAME=ai-fullstack-app
APP_ENV=development
APP_DEBUG=true

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:5173
API_V1_PREFIX=/api/v1

# Frontend
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000/api/v1

# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=app_db
MYSQL_USER=app_user
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_me_root

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=change_this_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

# SQLAlchemy
DATABASE_URL=mysql+aiomysql://app_user:change_me@mysql:3306/app_db
ALEMBIC_DATABASE_URL=mysql+pymysql://app_user:change_me@mysql:3306/app_db
